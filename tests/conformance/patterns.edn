; Data patterns: constants, variables, blanks, joins, tx position.

{:name "patterns/constant-value-match"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one :db/unique :db.unique/identity}
          {:db/ident :person/age :db/valueType :db.type/long :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/name "Alice" :person/age 30}
       {:db/id "b" :person/name "Bob" :person/age 25}
       {:db/id "c" :person/name "Carol" :person/age 30}]]
 :query [:find ?name :where [?e :person/age 30] [?e :person/name ?name]]
 :expected #{["Alice"] ["Carol"]}}

{:name "patterns/entity-returned-as-long"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/name "Alice"}]]
 :query [:find ?e :where [?e :person/name "Alice"]]
 :expected #{[#tempid "a"]}}

{:name "patterns/bound-entity-constant"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one}
          {:db/ident :person/age :db/valueType :db.type/long :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/name "Alice" :person/age 30}
       {:db/id "b" :person/name "Bob" :person/age 25}]]
 :query [:find ?age . :where [#tempid "a" :person/age ?age]]
 :expected 30}

{:name "patterns/lookup-ref-entity-position"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one :db/unique :db.unique/identity}
          {:db/ident :person/age :db/valueType :db.type/long :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/name "Alice" :person/age 30}]]
 :query [:find ?age . :where [[:person/name "Alice"] :person/age ?age]]
 :expected 30}

{:name "patterns/blank-matches-anything"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one}
          {:db/ident :person/age :db/valueType :db.type/long :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/name "Alice" :person/age 30}
       {:db/id "b" :person/name "Bob"}]]
 :query [:find ?name :where [?e :person/age _] [?e :person/name ?name]]
 :expected #{["Alice"]}}

{:name "patterns/join-on-shared-entity"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one}
          {:db/ident :person/age :db/valueType :db.type/long :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/name "Alice" :person/age 30}
       {:db/id "b" :person/name "Bob" :person/age 25}]]
 :query [:find ?name ?age :where [?e :person/name ?name] [?e :person/age ?age]]
 :expected #{["Alice" 30] ["Bob" 25]}}

{:name "patterns/join-across-ref"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one}
          {:db/ident :person/friend :db/valueType :db.type/ref :db/cardinality :db.cardinality/many}]
 :tx [[{:db/id "a" :person/name "Alice"}
       {:db/id "b" :person/name "Bob"}]
      [[:db/add #tempid "a" :person/friend #tempid "b"]]]
 :query [:find ?fname :where [?e :person/name "Alice"] [?e :person/friend ?f] [?f :person/name ?fname]]
 :expected #{["Bob"]}}

{:name "patterns/reverse-join-through-value-position"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one}
          {:db/ident :person/friend :db/valueType :db.type/ref :db/cardinality :db.cardinality/many}]
 :tx [[{:db/id "a" :person/name "Alice"}
       {:db/id "b" :person/name "Bob"}]
      [[:db/add #tempid "a" :person/friend #tempid "b"]]]
 :query [:find ?name :where [?e :person/friend #tempid "b"] [?e :person/name ?name]]
 :expected #{["Alice"]}}

{:name "patterns/no-match-yields-empty-set"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/name "Alice"}]]
 :query [:find ?e :where [?e :person/name "Nobody"]]
 :expected #{}}

{:name "patterns/keyword-valued-attribute"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one}
          {:db/ident :person/role :db/valueType :db.type/keyword :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/name "Alice" :person/role :role/admin}
       {:db/id "b" :person/name "Bob" :person/role :role/user}]]
 :query [:find ?name :where [?e :person/role :role/admin] [?e :person/name ?name]]
 :expected #{["Alice"]}}

{:name "patterns/keyword-value-round-trips-in-results"
 :schema [{:db/ident :person/role :db/valueType :db.type/keyword :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/role :role/admin}]]
 :query [:find ?role . :where [_ :person/role ?role]]
 :expected :role/admin}

{:name "patterns/string-match-is-case-sensitive"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/name "Alice"}]]
 :query [:find ?e :where [?e :person/name "alice"]]
 :expected #{}}

{:name "patterns/tx-constant-filters"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/name "Alice"}]
      [{:db/id "b" :person/name "Bob"}]]
 :query [:find ?name :where [?e :person/name ?name #tx 2]]
 :expected #{["Bob"]}}

{:name "patterns/tx-variable-binds-transaction-entity"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/name "Alice"}]]
 :query [:find ?tx . :where [_ :person/name "Alice" ?tx]]
 :expected #tx 1}

{:name "patterns/cardinality-many-returns-all-values"
 :schema [{:db/ident :person/nick :db/valueType :db.type/string :db/cardinality :db.cardinality/many}]
 :tx [[{:db/id "a" :person/nick ["Al" "Ali" "Big A"]}]]
 :query [:find [?nick ...] :where [#tempid "a" :person/nick ?nick]]
 :expected ["Al" "Ali" "Big A"]}

{:name "patterns/repeated-variable-must-unify"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one}
          {:db/ident :person/friend :db/valueType :db.type/ref :db/cardinality :db.cardinality/many}]
 :tx [[{:db/id "a" :person/name "Alice"}
       {:db/id "b" :person/name "Bob"}]
      [[:db/add #tempid "a" :person/friend #tempid "a"]
       [:db/add #tempid "a" :person/friend #tempid "b"]]]
 :query [:find ?name :where [?e :person/friend ?e] [?e :person/name ?name]]
 :expected #{["Alice"]}}

{:name "patterns/unknown-attribute-errors"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/name "Alice"}]]
 :query [:find ?e :where [?e :person/missing "x"]]
 :expect-error true}

{:name "patterns/contradictory-constants-empty"
 :schema [{:db/ident :person/age :db/valueType :db.type/long :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/age 30}]]
 :query [:find ?e :where [?e :person/age 30] [?e :person/age 31]]
 :expected #{}}

{:name "patterns/attribute-as-raw-entity-id"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/name "Alice"}]]
 :query [:find ?name :where [?e 100 ?name]]
 :expected #{["Alice"]}}

{:name "patterns/attribute-variable-binds-attr-entities"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one}
          {:db/ident :person/age :db/valueType :db.type/long :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/name "Alice" :person/age 30}]]
 :query [:find ?a :where [#tempid "a" ?a _]]
 :expected #{[100] [101]}}

{:name "patterns/value-variable-crosses-types"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one}
          {:db/ident :person/age :db/valueType :db.type/long :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/name "Alice" :person/age 30}]]
 :query [:find ?v :where [#tempid "a" _ ?v]]
 :expected #{["Alice"] [30]}}
