; :in bindings: scalars, tuples, collections, relations, multiple databases.

{:name "in/scalar"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one}
          {:db/ident :person/age :db/valueType :db.type/long :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/name "Alice" :person/age 30}
       {:db/id "b" :person/name "Bob" :person/age 25}]]
 :query [:find ?age . :in $ ?name :where [?e :person/name ?name] [?e :person/age ?age]]
 :args ["Bob"]
 :expected 25}

{:name "in/scalar-entity-argument"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/name "Alice"}]]
 :query [:find ?name . :in $ ?e :where [?e :person/name ?name]]
 :args [#tempid "a"]
 :expected "Alice"}

{:name "in/lookup-ref-argument"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one :db/unique :db.unique/identity}
          {:db/ident :person/age :db/valueType :db.type/long :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/name "Alice" :person/age 30}]]
 :query [:find ?age . :in $ ?e :where [?e :person/age ?age]]
 :args [[:person/name "Alice"]]
 :expected 30}

{:name "in/tuple"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one}
          {:db/ident :person/age :db/valueType :db.type/long :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/name "Alice" :person/age 30}
       {:db/id "b" :person/name "Bob" :person/age 25}]]
 :query [:find ?e :in $ [?name ?age] :where [?e :person/name ?name] [?e :person/age ?age]]
 :args [["Alice" 30]]
 :expected #{[#tempid "a"]}}

{:name "in/collection"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one}
          {:db/ident :person/age :db/valueType :db.type/long :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/name "Alice" :person/age 30}
       {:db/id "b" :person/name "Bob" :person/age 25}
       {:db/id "c" :person/name "Carol" :person/age 35}]]
 :query [:find ?name ?age :in $ [?name ...] :where [?e :person/name ?name] [?e :person/age ?age]]
 :args [["Alice" "Carol"]]
 :expected #{["Alice" 30] ["Carol" 35]}}

{:name "in/relation"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/name "Alice"}]]
 :query [:find ?name ?dept :in $ [[?name ?dept]] :where [_ :person/name ?name]]
 :args [[["Alice" "eng"] ["Nobody" "ops"]]]
 :expected #{["Alice" "eng"]}}

{:name "in/relation-cross-product-joins"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/name "Alice"} {:db/id "b" :person/name "Bob"}]]
 :query [:find ?name ?tag :in $ [?tag ...] :where [_ :person/name ?name]]
 :args [["x" "y"]]
 :expected #{["Alice" "x"] ["Alice" "y"] ["Bob" "x"] ["Bob" "y"]}}

{:name "in/missing-input-errors"
 :schema [{:db/ident :person/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/name "Alice"}]]
 :query [:find ?e :in $ ?name :where [?e :person/name ?name]]
 :expect-error true}

{:name "in/scalar-keyword-argument"
 :schema [{:db/ident :person/role :db/valueType :db.type/keyword :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :person/role :role/admin} {:db/id "b" :person/role :role/user}]]
 :query [:find ?e :in $ ?role :where [?e :person/role ?role]]
 :args [:role/admin]
 :expected #{[#tempid "a"]}}

{:name "in/no-database-pure-computation"
 :schema []
 :tx []
 :query [:find ?c . :in $ ?a ?b :where [(+ ?a ?b) ?c]]
 :args [2 3]
 :expected 5}
