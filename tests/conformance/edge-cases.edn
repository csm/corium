; Edge cases: value types at the boundary, empty results, coercions.

{:name "edge/instant-values-round-trip"
 :schema [{:db/ident :e/at :db/valueType :db.type/instant :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :e/at #inst 1700000000000}]]
 :query [:find ?t . :where [_ :e/at ?t]]
 :expected #inst 1700000000000}

{:name "edge/instant-coerces-from-long-in-tx"
 :schema [{:db/ident :e/at :db/valueType :db.type/instant :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :e/at 1700000000000}]]
 :query [:find ?t . :where [_ :e/at ?t]]
 :expected #inst 1700000000000}

{:name "edge/instant-comparison"
 :schema [{:db/ident :e/at :db/valueType :db.type/instant :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :e/at #inst 100} {:db/id "b" :e/at #inst 200}]]
 :query [:find ?t :where [_ :e/at ?t] [(< ?t #inst 150)]]
 :expected #{[#inst 100]}}

{:name "edge/uuid-values"
 :schema [{:db/ident :e/id :db/valueType :db.type/uuid :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :e/id #uuid "0000000000000000000000000000002a"}]]
 :query [:find ?e :where [?e :e/id #uuid "0000000000000000000000000000002a"]]
 :expected #{[#tempid "a"]}}

{:name "edge/boolean-values"
 :schema [{:db/ident :e/on :db/valueType :db.type/boolean :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :e/on true} {:db/id "b" :e/on false}]]
 :query [:find ?e :where [?e :e/on false]]
 :expected #{[#tempid "b"]}}

{:name "edge/double-ordering"
 :schema [{:db/ident :e/x :db/valueType :db.type/double :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :e/x -1.5} {:db/id "b" :e/x 0.0} {:db/id "c" :e/x 2.25}]]
 :query [:find ?x :where [_ :e/x ?x] [(< ?x 0.5)]]
 :expected #{[-1.5] [0.0]}}

{:name "edge/long-matches-double-in-predicate-not-index"
 ; 1 (long) and 1.0 (double) compare equal in predicates but are distinct
 ; stored values: an index match on long 1 finds nothing.
 :schema [{:db/ident :e/x :db/valueType :db.type/double :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :e/x 1.0}]]
 :query [:find ?x :where [_ :e/x ?x] [(= ?x 1)]]
 :expected #{[1.0]}}

{:name "edge/empty-database-query"
 :schema [{:db/ident :p/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one}]
 :tx []
 :query [:find ?e :where [?e :p/name _]]
 :expected #{}}

{:name "edge/query-without-where-with-inputs"
 :schema []
 :tx []
 :query [:find ?x :in $ [?x ...]]
 :args [[1 2 3]]
 :expected #{[1] [2] [3]}}

{:name "edge/nonexistent-lookup-ref-in-pattern-matches-nothing"
 :schema [{:db/ident :p/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one :db/unique :db.unique/identity}
          {:db/ident :p/age :db/valueType :db.type/long :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :p/name "Alice" :p/age 30}]]
 :query [:find ?age :where [[:p/name "Nobody"] :p/age ?age]]
 :expected #{}}

{:name "edge/unknown-keyword-value-matches-nothing"
 :schema [{:db/ident :p/role :db/valueType :db.type/keyword :db/cardinality :db.cardinality/one}]
 :tx [[{:db/id "a" :p/role :role/admin}]]
 :query [:find ?e :where [?e :p/role :role/never-written]]
 :expected #{}}

{:name "edge/self-referencing-entity"
 :schema [{:db/ident :p/name :db/valueType :db.type/string :db/cardinality :db.cardinality/one}
          {:db/ident :p/knows :db/valueType :db.type/ref :db/cardinality :db.cardinality/many}]
 :tx [[{:db/id "a" :p/name "Alice"}]
      [[:db/add #tempid "a" :p/knows #tempid "a"]]]
 :query [:find ?n :where [?e :p/knows ?e] [?e :p/name ?n]]
 :expected #{["Alice"]}}
